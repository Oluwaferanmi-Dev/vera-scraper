# Server-only credentials. Never expose this key in a browser or commit it.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-key
# Browser-safe key from Supabase Dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key

# Only these signed-in email addresses can use the Vera review interface.
# Comma-separate multiple reviewers. Do not put this in NEXT_PUBLIC_*.
VERA_REVIEWER_EMAILS=vera@example.com

# Server-only GitHub token used only when Vera clicks “Run scraper”.
# Use a fine-grained token restricted to this repository with Actions: Read and write.
GITHUB_REPOSITORY=Oluwaferanmi-Dev/vera-scraper
GITHUB_ACTIONS_TOKEN=github_pat_replace_me
GITHUB_WORKFLOW_REF=main

# Identifies this crawler to site operators.
SCRAPER_USER_AGENT=VeraEventDiscoveryBot/1.0 (+mailto:ops@example.com)

# Delay between all site requests in milliseconds. Keep this at 2 seconds or higher.
REQUEST_DELAY_MS=2000

# Meetup is API-only. Supply an approved OAuth/API token and enable the source only
# after confirming its current developer-plan access and endpoint contract.
MEETUP_API_TOKEN=
